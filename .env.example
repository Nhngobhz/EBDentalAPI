# Copy this file to `.env` and fill in real values.
# Every variable has a safe default in app/config.py, but you should at
# least set SECRET_KEY, DATABASE_URL, and your own credentials below
# before running this in anything beyond local testing.

APP_NAME=EBDentalSupply
ENVIRONMENT=development
DEBUG=true
# Public URL of this API - used to build the links inside confirmation /
# password-reset emails. Change this to your real domain in production.
BASE_URL=http://localhost:8000

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://store_user:store_password@localhost:5432/store_db
# Leave false and use `alembic upgrade head` instead (recommended).
# Only set true for quick local experiments.
AUTO_CREATE_TABLES=false

# --- Security ----------------------------------------------------------------
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30

# --- CORS --------------------------------------------------------------------
# Comma-separated list, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# --- Outbound email (SMTP) ----------------------------------------------------
# Leave MAIL_USERNAME empty to run in "dry run" mode - emails get logged
# instead of sent, which is fine for local development.
# Example values for a Gmail account using an App Password:
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME=EBDentalSupply
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# --- Telegram bot --------------------------------------------------------------
# Leave both empty to disable Telegram notifications entirely.
# 1. Message @BotFather on Telegram -> /newbot -> copy the token below.
# 2. Send any message to your new bot (or add it to a group).
# 3. Open https://api.telegram.org/bot<TOKEN>/getUpdates and copy the chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: if the group has "Topics" enabled, route errors/logins into
# separate topics by setting their message_thread_id (found the same way,
# via getUpdates, after posting in that topic). Leave empty for General.
TELEGRAM_ERROR_TOPIC_ID=
TELEGRAM_LOGIN_TOPIC_ID=
TELEGRAM_ORDER_TOPIC_ID=
# Random shared secret Telegram must present when calling POST /telegram/webhook/<secret>
# (see app/routers/telegram_webhook.py) - required for the order Delivered/Cancelled
# buttons to work. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Also requires BASE_URL above to be a real public HTTPS URL Telegram can reach (a local
# tunnel like ngrok/cloudflared works for testing) - on startup, if both are set, the app
# automatically registers the webhook with Telegram.
TELEGRAM_WEBHOOK_SECRET=

# --- File uploads --------------------------------------------------------------
UPLOAD_DIR=static/uploads
MAX_IMAGE_SIZE_MB=5
MAX_PDF_SIZE_MB=20

# --- File storage (Cloudflare R2) ------------------------------------------------
# Leave R2_ACCESS_KEY_ID empty to store uploads on local disk instead (under
# UPLOAD_DIR, served via /static) - handy for local development.
# 1. Create a bucket: Cloudflare dashboard -> R2 -> Create bucket.
# 2. Create an API token: R2 -> Manage API Tokens -> Create API Token
#    (Object Read & Write, scoped to the bucket) -> copy Access Key ID/Secret.
# 3. Enable public access on the bucket (R2.dev subdomain or a custom domain)
#    and put that base URL below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
